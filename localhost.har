            "compression": 0,
            "text": "import { createHotContext as __vite__createHotContext } from \"/@vite/client\";import.meta.hot = __vite__createHotContext(\"/src/styles/themes.css\");import { updateStyle as __vite__updateStyle, removeStyle as __vite__removeStyle } from \"/@vite/client\"\nconst __vite__id = \"C:/Users/steve/Desktop/Python Template/Python Template/Template React/V0.01/client/src/styles/themes.css\"\nconst __vite__css = \"/* ===== THEMA ONDERSTEUNING ===== */\\r\\n/* Dark en Light thema variabelen en stijlen */\\r\\n\\r\\n/* CSS Custom Properties voor thema's */\\r\\n:root {\\r\\n    /* Light Theme (default) */\\r\\n    --bg-primary: #f8f9fa;\\r\\n    --bg-secondary: #ffffff;\\r\\n    --bg-tertiary: #f1f3f4;\\r\\n    --text-primary: #181c22; /* Zeer donker voor maximale leesbaarheid */\\r\\n    --text-secondary: #3d4852; /* Donkergrijs, goed leesbaar op licht */\\r\\n    --text-muted: #6c757d; /* Iets donkerder dan standaard muted */\\r\\n    --border-color: #d1d5db;\\r\\n    --border-color-light: #e5e7eb;\\r\\n    --accent-color: #2c5f41;\\n    --accent-color-rgb: 44, 95, 65;\\n    --accent-hover: #1a3c28;\\n    --accent-text-color: #ffffff;\\n    --success-color: #198754;\\r\\n    --warning-color: #fd7e14;\\r\\n    --danger-color: #dc3545;\\r\\n    --info-color: #0dcaf0;\\r\\n    \\r\\n    /* Sidebar specifiek */\\r\\n    --sidebar-bg: linear-gradient(135deg, #2c5f41 0%, #1e4530 100%);\\n    --sidebar-text: #ffffff;\\n    --sidebar-text-muted: rgba(255, 255, 255, 0.85);\\n    --sidebar-hover: rgba(255, 255, 255, 0.1);\\n    --sidebar-active: rgba(255, 255, 255, 0.2);\\n    --sidebar-accent-start: var(--accent-color);\\n    --sidebar-accent-end: var(--sidebar-accent-second, var(--accent-color));\\n    \\r\\n    /* Shadow en effects */\\r\\n    --shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24);\\n    --shadow-md: 0 3px 6px rgba(0,0,0,0.15), 0 2px 4px rgba(0,0,0,0.12);\\n    --shadow-lg: 0 10px 20px rgba(0,0,0,0.15), 0 3px 6px rgba(0,0,0,0.10);\\n    --header-bg: var(--bg-secondary);\\n    --header-border: var(--border-color);\\n}\\n\\r\\n/* Dark Theme */\\r\\n/* Donker thema: identiek aan auto-dark voor volledige consistentie */\\r\\n[data-theme=\\\"dark\\\"], .theme-dark {\\n    --bg-primary: color-mix(in srgb, #0e1112 90%, var(--accent-color));\\n    --bg-secondary: color-mix(in srgb, #1a1f22 88%, var(--accent-color));\\n    --bg-tertiary: color-mix(in srgb, #262c31 86%, var(--accent-color));\\n    --text-primary: #f8f9fa;\\n    --text-secondary: #ced4da;\\n    --text-muted: #7b8791;\\n    --border-color: color-mix(in srgb, #3a4249 85%, var(--accent-color));\\n    --border-color-light: color-mix(in srgb, #2f363c 88%, var(--accent-color));\\n    --success-color: #22c55e;\\n    --warning-color: #f59e0b;\\n    --danger-color: #ef4444;\\n    --info-color: #06b6d4;\\n    --sidebar-bg: linear-gradient(135deg,\\n        color-mix(in srgb, #0b1114 86%, var(--accent-color)) 0%,\\n        color-mix(in srgb, #0d1417 90%, var(--accent-color)) 100%);\\n    --sidebar-accent-start: color-mix(in srgb, #0b1114 68%, var(--accent-color));\\n    --sidebar-accent-end: color-mix(in srgb, #07090b 78%, var(--accent-color));\\n    --sidebar-text: #f8fafc;\\r\\n    --sidebar-text-muted: rgba(248, 250, 252, 0.85);\\r\\n    --sidebar-hover: rgba(241, 245, 249, 0.1);\\r\\n    --sidebar-active: rgba(241, 245, 249, 0.2);\\n    --header-bg: color-mix(in srgb, #14181c 85%, var(--accent-color));\\n    --header-border: color-mix(in srgb, #283038 80%, var(--accent-color));\\n    --shadow-sm: 0 1px 3px rgba(0,0,0,0.4), 0 1px 2px rgba(0,0,0,0.3);\\n    --shadow-md: 0 3px 6px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.4);\\r\\n    --shadow-lg: 0 10px 20px rgba(0,0,0,0.6), 0 3px 6px rgba(0,0,0,0.5);\\r\\n}\\r\\n\\r\\n/* Auto theme: respecteer systeem voorkeur */\\r\\n@media (prefers-color-scheme: dark) {\\r\\n    [data-theme=\\\"auto\\\"] {\\n        --bg-primary: color-mix(in srgb, #0e1112 90%, var(--accent-color));\\n        --bg-secondary: color-mix(in srgb, #1a1f22 88%, var(--accent-color));\\n        --bg-tertiary: color-mix(in srgb, #262c31 86%, var(--accent-color));\\n        --text-primary: #f8f9fa;\\n        --text-secondary: #ced4da;\\n        --text-muted: #7b8791;\\n        --border-color: color-mix(in srgb, #3a4249 85%, var(--accent-color));\\n        --border-color-light: color-mix(in srgb, #2f363c 88%, var(--accent-color));\\n        --success-color: #22c55e;\\n        --warning-color: #f59e0b;\\n        --danger-color: #ef4444;\\n        --info-color: #06b6d4;\\n        \\n        --sidebar-bg: linear-gradient(135deg,\\n            color-mix(in srgb, #0b1114 86%, var(--accent-color)) 0%,\\n            color-mix(in srgb, #0d1417 90%, var(--accent-color)) 100%);\\n        --sidebar-accent-start: color-mix(in srgb, #0b1114 68%, var(--accent-color));\\n        --sidebar-accent-end: color-mix(in srgb, #07090b 78%, var(--accent-color));\\n        --sidebar-text: #f8fafc;\\r\\n        --sidebar-text-muted: rgba(248, 250, 252, 0.85);\\r\\n        --sidebar-hover: rgba(241, 245, 249, 0.1);\\r\\n        --sidebar-active: rgba(241, 245, 249, 0.2);\\n        --header-bg: color-mix(in srgb, #14181c 85%, var(--accent-color));\\n        --header-border: color-mix(in srgb, #283038 80%, var(--accent-color));\\n        \\n        --shadow-sm: 0 1px 3px rgba(0,0,0,0.4), 0 1px 2px rgba(0,0,0,0.3);\\n        --shadow-md: 0 3px 6px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.4);\\r\\n        --shadow-lg: 0 10px 20px rgba(0,0,0,0.6), 0 3px 6px rgba(0,0,0,0.5);\\r\\n    }\\r\\n}\\r\\n\\r\\n/* ===== DISPLAY MODE ONDERSTEUNING ===== */\\n/* Full display mode is now the default */\\n\\n:root {\\n    --font-size-base: 1rem;\\n    --font-size-sm: 0.875rem;\\n    --font-size-lg: 1.125rem;\\n    --padding-sm: 0.5rem;\\r\\n    --padding-md: 0.75rem;\\r\\n    --padding-lg: 1rem;\\r\\n    --margin-sm: 0.5rem;\\r\\n    --margin-md: 0.75rem;\\r\\n    --margin-lg: 1rem;\\r\\n    --line-height: 1.6;\\r\\n    --border-radius: 6px;\\r\\n    --element-height: 40px;\\n    --button-height: 40px;\\n    --input-height: 40px;\\n}\\n\\r\\n/* ===== BASIS ELEMENTEN MET THEMA ONDERSTEUNING ===== */\\r\\n\\r\\nbody {\\r\\n    background-color: var(--bg-primary) !important;\\r\\n    color: var(--text-primary);\\r\\n    font-size: var(--font-size-base);\\r\\n    line-height: var(--line-height);\\r\\n    transition: background-color 0.3s ease, color 0.3s ease;\\r\\n}\\r\\n\\r\\n/* Headings met thema kleuren */\\r\\nh1, h2, h3, h4, h5, h6 {\\r\\n    color: var(--accent-color);\\r\\n    margin-bottom: var(--margin-md);\\r\\n}\\r\\n\\r\\n/* Links met thema kleuren */\\r\\na {\\r\\n    color: var(--accent-color);\\r\\n    transition: color 0.2s ease;\\r\\n}\\r\\n\\r\\na:hover {\\r\\n    color: var(--accent-hover);\\r\\n}\\r\\n\\r\\n/* Cards en containers */\\r\\n.card, .settings-card, .content-card {\\r\\n    background-color: var(--bg-secondary);\\r\\n    border: 1px solid var(--border-color);\\r\\n    box-shadow: var(--shadow-sm);\\r\\n    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;\\r\\n}\\r\\n\\r\\n.card:hover, .settings-card:hover {\\r\\n    box-shadow: var(--shadow-md);\\r\\n}\\r\\n\\r\\n/* Borders */\\r\\n.border {\\r\\n    border-color: var(--border-color) !important;\\r\\n}\\r\\n\\r\\n.border-light {\\r\\n    border-color: var(--border-color-light) !important;\\r\\n}\\r\\n\\r\\n/* Text colors */\\r\\n.text-muted {\\r\\n    color: var(--text-muted) !important;\\r\\n}\\r\\n\\r\\n.text-secondary {\\r\\n    color: var(--text-secondary) !important;\\r\\n}\\r\\n\\r\\n/* Buttons met thema ondersteuning */\\r\\n.btn-primary {\\r\\n    background-color: var(--accent-color);\\r\\n    border-color: var(--accent-color);\\r\\n    color: white;\\r\\n    height: var(--button-height);\\r\\n    padding: 0 var(--padding-lg);\\r\\n    font-size: var(--font-size-base);\\r\\n    border-radius: var(--border-radius);\\r\\n}\\r\\n\\r\\n.btn-primary:hover {\\r\\n    background-color: var(--accent-hover);\\r\\n    border-color: var(--accent-hover);\\r\\n}\\r\\n\\r\\n/* Forms met thema ondersteuning */\\r\\n.form-control, .form-select {\\r\\n    background-color: var(--bg-secondary);\\r\\n    border-color: var(--border-color);\\r\\n    color: var(--text-primary);\\r\\n    height: var(--input-height);\\r\\n    font-size: var(--font-size-base);\\r\\n    border-radius: var(--border-radius);\\r\\n    padding: 0 var(--padding-md);\\r\\n    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;\\r\\n}\\r\\n\\r\\n.form-control:focus, .form-select:focus {\\r\\n    border-color: var(--accent-color);\\r\\n    box-shadow: 0 0 0 0.2rem rgba(44, 95, 65, 0.25);\\r\\n    background-color: var(--bg-secondary);\\r\\n    color: var(--text-primary);\\r\\n}\\r\\n\\r\\n.form-control::placeholder {\\r\\n    color: var(--text-muted);\\r\\n}\\r\\n\\r\\n/* Tables met thema ondersteuning */\\r\\n.table {\\r\\n    color: var(--text-primary);\\r\\n    background-color: var(--bg-secondary);\\r\\n}\\r\\n\\r\\n.table th {\\r\\n    background-color: var(--bg-tertiary);\\r\\n    border-color: var(--border-color);\\r\\n    color: var(--text-primary);\\r\\n    font-size: var(--font-size-sm);\\r\\n    padding: var(--padding-sm) var(--padding-md);\\r\\n}\\r\\n\\r\\n.table td {\\r\\n    border-color: var(--border-color);\\r\\n    font-size: var(--font-size-base);\\r\\n    padding: var(--padding-sm) var(--padding-md);\\r\\n}\\r\\n\\r\\n.table-striped tbody tr:nth-of-type(odd) {\\r\\n    background-color: var(--bg-tertiary);\\r\\n}\\r\\n\\r\\n/* Modals met thema ondersteuning */\\r\\n.modal-content {\\r\\n    background-color: var(--bg-secondary);\\r\\n    border-color: var(--border-color);\\r\\n    color: var(--text-primary);\\r\\n}\\r\\n\\r\\n.modal-header {\\r\\n    border-bottom-color: var(--border-color);\\r\\n}\\r\\n\\r\\n.modal-footer {\\r\\n    border-top-color: var(--border-color);\\r\\n}\\r\\n\\r\\n/* Alerts met thema ondersteuning */\\r\\n.alert {\\r\\n    border-radius: var(--border-radius);\\r\\n    padding: var(--padding-md);\\r\\n    font-size: var(--font-size-base);\\r\\n}\\r\\n\\r\\n.alert-success {\\r\\n    background-color: color-mix(in srgb, var(--success-color) 15%, var(--bg-secondary));\\r\\n    border-color: var(--success-color);\\r\\n    color: var(--success-color);\\r\\n}\\r\\n\\r\\n.alert-warning {\\r\\n    background-color: color-mix(in srgb, var(--warning-color) 15%, var(--bg-secondary));\\r\\n    border-color: var(--warning-color);\\r\\n    color: var(--warning-color);\\r\\n}\\r\\n\\r\\n.alert-danger {\\r\\n    background-color: color-mix(in srgb, var(--danger-color) 15%, var(--bg-secondary));\\r\\n    border-color: var(--danger-color);\\r\\n    color: var(--danger-color);\\r\\n}\\r\\n\\r\\n.alert-info {\\r\\n    background-color: color-mix(in srgb, var(--info-color) 15%, var(--bg-secondary));\\r\\n    border-color: var(--info-color);\\r\\n    color: var(--info-color);\\r\\n}\\r\\n\\r\\n/* ===== TRANSITIONS VOOR SMOOTH THEME SWITCHING ===== */\\r\\n\\r\\n* {\\r\\n    transition: background-color 0.3s ease, \\r\\n                color 0.3s ease, \\r\\n                border-color 0.3s ease,\\r\\n                box-shadow 0.3s ease;\\r\\n}\\r\\n\\r\\n/* Uitzondering voor elementen die geen transition moeten hebben */\\r\\n.no-transition,\\r\\n.no-transition * {\\r\\n    transition: none !important;\\r\\n}\\r\\n\\r\\n/* ===== JAVASCRIPT HELPERS ===== */\\r\\n\\r\\n/* Classes voor immediate theme application */\\r\\n.theme-light { \\r\\n    color-scheme: light;\\r\\n}\\r\\n\\r\\n.theme-dark { \\r\\n    color-scheme: dark;\\r\\n}\\r\\n\\r\\n.theme-auto { \\r\\n    color-scheme: light dark;\\r\\n}\\r\\n\\r\\n/* ===== HEADER EN MAIN CONTENT THEMING ===== */\\r\\n\\r\\n.top-header {\\r\\n    background-color: var(--bg-secondary) !important;\\r\\n    color: var(--text-primary) !important;\\r\\n    border-bottom: 1px solid var(--border-color) !important;\\r\\n}\\r\\n\\r\\n.main-content {\\r\\n    background-color: var(--bg-primary) !important;\\r\\n}\\r\\n\\r\\n.content-area {\\r\\n    background-color: var(--bg-primary) !important;\\r\\n}\\r\\n\\r\\n.page-container {\\r\\n    background-color: transparent !important;\\r\\n}\\r\\n\\r\\n/* ===== SCROLLBAR THEMING ===== */\\r\\n\\r\\n/* Webkit scrollbars (Chrome, Safari, Edge) */\\r\\n::-webkit-scrollbar {\\r\\n    width: 8px;\\r\\n    height: 8px;\\r\\n}\\r\\n\\r\\n::-webkit-scrollbar-track {\\r\\n    background: var(--bg-tertiary);\\r\\n}\\r\\n\\r\\n::-webkit-scrollbar-thumb {\\r\\n    background: var(--border-color);\\r\\n    border-radius: 4px;\\r\\n}\\r\\n\\r\\n::-webkit-scrollbar-thumb:hover {\\r\\n    background: var(--text-muted);\\r\\n}\\r\\n\\r\\n/* Firefox scrollbars */\\r\\n* {\\r\\n    scrollbar-width: thin;\\r\\n    scrollbar-color: var(--border-color) var(--bg-tertiary);\\r\\n}\\r\\n\"\n__vite__updateStyle(__vite__id, __vite__css)\nimport.meta.hot.accept()\nimport.meta.hot.prune(() => __vite__removeStyle(__vite__id))"
